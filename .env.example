# =============================================================================
# AutoTreeGen — пример переменных окружения
# Скопировать в .env и заполнить значениями. .env в .gitignore.
# =============================================================================

# ---- Общее ----
APP_ENV=development                   # development | staging | production
LOG_LEVEL=DEBUG                       # DEBUG | INFO | WARNING | ERROR

# ---- PostgreSQL (соответствует docker-compose.yml) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=autotreegen
POSTGRES_USER=autotreegen
POSTGRES_PASSWORD=change-me-in-local-env
DATABASE_URL=postgresql+asyncpg://autotreegen:change-me-in-local-env@localhost:5432/autotreegen

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---- MinIO (S3-совместимый storage) ----
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_GEDCOM=gedcom
S3_BUCKET_DNA=dna
S3_BUCKET_DOCUMENTS=documents

# ---- Внешние API (заполнять только при работе с соответствующей фазой) ----
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=        # путь к JSON service-account для GCP

# ---- Аутентификация: Clerk (Phase 4.10, ADR-0033) ----
# Frontend (Next.js — apps/web). Подхватываются automaticaly через
# `@clerk/nextjs`; копировать также в apps/web/.env.local.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Backend (parser-service / dna-service / notification-service).
# Issuer берётся из Clerk dashboard → API Keys → Show JWT Public Key
# (подсказывает issuer URL). Без этого endpoint'ы возвращают 503.
PARSER_SERVICE_CLERK_ISSUER=https://accept-XXXX.clerk.accounts.dev
PARSER_SERVICE_CLERK_JWKS_URL=
PARSER_SERVICE_CLERK_AUDIENCE=
# Webhook signing secret — Clerk dashboard → Webhooks → Endpoint → Signing Secret.
PARSER_SERVICE_CLERK_WEBHOOK_SECRET=whsec_xxxxx

DNA_SERVICE_CLERK_ISSUER=https://accept-XXXX.clerk.accounts.dev
DNA_SERVICE_CLERK_JWKS_URL=
DNA_SERVICE_CLERK_AUDIENCE=

NOTIFICATION_SERVICE_CLERK_ISSUER=https://accept-XXXX.clerk.accounts.dev
NOTIFICATION_SERVICE_CLERK_JWKS_URL=
NOTIFICATION_SERVICE_CLERK_AUDIENCE=

# ---- Платежи (Фаза 12) ----
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Transactional email (Фаза 12.2, ADR-0039) ----
# RESEND_API_KEY: re_* от Resend.com — провайдер transactional-email.
# Без ключа email-service работает в bypass-режиме
# (EMAIL_SERVICE_ENABLED=false): /send возвращает status=skipped_optout
# для всех, провайдер не вызывается. Регистрация: https://resend.com/.
RESEND_API_KEY=
# Verified Resend domain. До добавления собственного домена можно
# использовать onboarding-домен resend.dev для local-тестов.
RESEND_FROM=noreply@smartreedna.com

# ---- Telegram bot (Phase 14.0, ADR-0040) ----
# TELEGRAM_BOT_TOKEN: токен от @BotFather. Без него telegram-bot стартует,
# но любой исходящий вызов (`message.answer(...)` в /start) вернёт 401.
TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_WEBHOOK_SECRET: 32+ символа random URL-safe; передаётся в
# Telegram при `setWebhook(secret_token=...)`. Без него /telegram/webhook
# отвечает 503 (отказ обслуживания), потому что unauthenticated webhook
# = anyone can dispatch updates.
TELEGRAM_BOT_WEBHOOK_SECRET=
# TELEGRAM_BOT_LINK_TTL_SECONDS: TTL one-time link-токена (default 900 = 15 min).
TELEGRAM_BOT_LINK_TTL_SECONDS=900
# TELEGRAM_BOT_WEB_BASE_URL: база web-у для генерации /telegram/link?token=... ссылок.
TELEGRAM_BOT_WEB_BASE_URL=http://localhost:3000

# ---- Sentry (мониторинг) ----
SENTRY_DSN=
