# =============================================================================
# AutoTreeGen — пример переменных окружения
# Скопировать в .env и заполнить значениями. .env в .gitignore.
# =============================================================================

# ---- Общее ----
APP_ENV=development                   # development | staging | production
LOG_LEVEL=DEBUG                       # DEBUG | INFO | WARNING | ERROR

# ---- PostgreSQL (соответствует docker-compose.yml) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=autotreegen
POSTGRES_USER=autotreegen
POSTGRES_PASSWORD=change-me-in-local-env
DATABASE_URL=postgresql+asyncpg://autotreegen:change-me-in-local-env@localhost:5432/autotreegen

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---- MinIO (S3-совместимый storage) ----
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_GEDCOM=gedcom
S3_BUCKET_DNA=dna
S3_BUCKET_DOCUMENTS=documents

# ---- Внешние API (заполнять только при работе с соответствующей фазой) ----
# ANTHROPIC_API_KEY: llm-services (Phase 10.0+) — Claude API wrapper.
# Без ключа LlmPlaceMatchRule работает в zero-cost mode (no-op);
# normalize_place_name / disambiguate_name_variants поднимут MissingApiKeyError.
# Получить: https://console.anthropic.com/.
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=        # путь к JSON service-account для GCP

# ---- Аутентификация (Фаза 4) ----
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---- Платежи (Фаза 12) ----
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Sentry (мониторинг) ----
SENTRY_DSN=
