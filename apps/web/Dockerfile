# =============================================================================
# Next.js standalone build for Cloud Run.
#
# Multi-stage:
#   1. deps  — install pnpm, fetch deps with the workspace lockfile.
#   2. build — compile Next.js with `output: "standalone"` (next.config.ts).
#   3. run   — slim node image with only the standalone bundle + static assets.
#
# Build context = repo root (so we can see pnpm-lock.yaml + workspace YAML).
# Build:  docker build -f apps/web/Dockerfile -t web .
# =============================================================================

FROM node:22-slim AS deps
WORKDIR /repo

RUN corepack enable && corepack prepare pnpm@9 --activate

# Workspace metadata. Copy lockfile, root package.json, workspace declaration,
# and only the apps/web manifest — all `pnpm install --filter web` needs.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json apps/web/

# Frozen lockfile = reproducible install in CI; tolerate Linux platform differences.
RUN pnpm install --filter @autotreegen/web... --frozen-lockfile

# -----------------------------------------------------------------------------
FROM node:22-slim AS build
WORKDIR /repo

RUN corepack enable && corepack prepare pnpm@9 --activate

COPY --from=deps /repo/node_modules ./node_modules
COPY --from=deps /repo/apps/web/node_modules ./apps/web/node_modules
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/ apps/web/

ENV NEXT_TELEMETRY_DISABLED=1
RUN pnpm --filter @autotreegen/web build

# -----------------------------------------------------------------------------
FROM node:22-slim AS run
WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0

# Run as non-root.
RUN groupadd --system --gid 1001 nodejs \
 && useradd  --system --uid 1001 --gid nodejs nextjs

# Standalone output bundles the minimal node_modules subtree next to server.js.
# Static assets and the public/ directory are copied separately — Next.js
# expects them at runtime even with standalone output.
COPY --from=build --chown=nextjs:nodejs /repo/apps/web/.next/standalone ./
COPY --from=build --chown=nextjs:nodejs /repo/apps/web/.next/static ./apps/web/.next/static
# Static assets (`public/`) are intentionally not copied — apps/web has none
# in this phase. Add a `COPY ... apps/web/public` line if you introduce one.

USER nextjs
EXPOSE 3000

# server.js is generated by Next.js inside the standalone bundle.
CMD ["node", "apps/web/server.js"]
