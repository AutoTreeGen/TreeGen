# billing-service ENV (Phase 12.0, ADR-0042).
# Скопируй в .env и заполни.

# DB
BILLING_SERVICE_DATABASE_URL=postgresql+asyncpg://autotreegen:autotreegen@localhost:5433/autotreegen

# Stripe API
BILLING_SERVICE_STRIPE_API_KEY=sk_test_replace_me
BILLING_SERVICE_STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Stripe Prices (см. https://dashboard.stripe.com/products)
# Free — placeholder; FREE plan не имеет Checkout Session.
BILLING_SERVICE_STRIPE_PRICE_FREE=
BILLING_SERVICE_STRIPE_PRICE_PRO=price_replace_me_pro
BILLING_SERVICE_STRIPE_PRICE_PREMIUM=price_replace_me_premium

# Inter-service: куда POST'ить payment_succeeded/payment_failed emails.
BILLING_SERVICE_EMAIL_SERVICE_URL=http://email-service:8000

# Redirect URLs (Stripe Checkout success/cancel)
BILLING_SERVICE_CHECKOUT_SUCCESS_URL=http://localhost:3000/settings/billing?checkout=success
BILLING_SERVICE_CHECKOUT_CANCEL_URL=http://localhost:3000/pricing?checkout=cancel
BILLING_SERVICE_PORTAL_RETURN_URL=http://localhost:3000/settings/billing

# Feature flag (false = пропускаем все entitlement-проверки, dev/CI mode)
BILLING_SERVICE_BILLING_ENABLED=true

# Сколько дней даём доступ после past_due (см. ADR-0042).
BILLING_SERVICE_PAST_DUE_GRACE_DAYS=7
