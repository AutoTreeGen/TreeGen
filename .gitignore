# =============================================================================
# AutoTreeGen / SmarTreeDNA — .gitignore
# =============================================================================

# ---- Секреты и окружение ----
.env
.env.*
!.env.example
# TLS / сертификаты / приватные ключи (все распространённые форматы)
*.pem
*.key
*.crt
*.cer
*.p8
*.p12
*.pfx
*.jks
*.keystore
# SSH-ключи
id_rsa
id_dsa
id_ecdsa
id_ed25519
*.ppk
# Package-manager registry credentials
.npmrc
!.npmrc.example
# Cloud-provider credential files
gcp-key.json
service-account*.json
aws-credentials
secrets/
.secrets.baseline.local

# ---- Личные / чувствительные данные (НИКОГДА не коммитить) ----
# Личный GED-файл владельца
Ztree.ged
*Ztree*.ged
# Личные/приватные образцы для тестирования
packages/gedcom-parser/samples/personal/
# DNA-данные (special category по GDPR — см. ADR-0012)
**/dna-data/
**/dna_kits/
packages/dna-analysis/test_data/real/
*.dna
*.dna.csv
*.dna.zip
*_dna_*.csv
# HapMap genetic map (~50MB, public domain reference data — см. ADR-0014).
# Скачивается через packages/dna-analysis/scripts/download_genetic_map.py.
# Test fixture (одна хромосома) живёт в tests/fixtures/genetic_map/ и НЕ под этим правилом.
packages/dna-analysis/data/genetic_maps/

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
# Frontend src/lib не относится к Python-сборкам выше — явно возвращаем его обратно.
!apps/*/src/lib/
!apps/*/src/lib/**
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Python virtual envs
.venv/
venv/
ENV/
env/
.env-*/

# Python tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.hypothesis/
coverage.xml
*.cover
.cache

# uv
.uv/
uv.lock.local

# Jupyter
.ipynb_checkpoints/

# ---- Node / TypeScript ----
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/
.next/
.nuxt/
out/
build/
.turbo/
.vercel/
.cache/
*.tsbuildinfo
.swc/

# ---- IDE / редакторы ----
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
# Visual Studio (.vs/) — scratch-папка с бинарным состоянием IDE: slnx.sqlite,
# .wsuo, .vsidx-индексы, DocumentLayout.json. Никогда не должна быть в репо
# (содержит локальные пути и состояние workspace одного разработчика).
.vs/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
.cursor/

# ---- MCP / dev-tooling конфиги ----
# .mcp.json — конфиг локального MCP-сервера (filesystem, shell и т.п.).
# Привязан к рабочей машине разработчика, не должен утекать в репо.
.mcp.json

# ---- Docker / dev ----
.docker/
docker-compose.override.yml
volumes/
data/

# ---- Логи и временные файлы ----
*.log
logs/
tmp/
temp/
.tmp/

# ---- Тестовые артефакты ----
test-results/
playwright-report/
playwright/.cache/

# ---- OS ----
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# ---- Terraform ----
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
crash.log
*.tfvars
!*.tfvars.example

# ---- Локальные файлы Claude ----
.claude/settings.local.json
.claude/cache/
.claude/*.lock
.claude/scheduled_tasks.lock

# ---- pre-commit ----
.pre-commit-cache/

# ---- Локальные dev-скрипты (не для коммита) ----
# Личные batch/PowerShell-обёртки для install/dev/restore цикла на машине
# владельца. Содержат hardcoded пути и не предполагают переиспользования.
*.log.cd
install-and-dev.bat
just-install.bat
rebuild-step1-restore.bat
scripts/auto-merge.ps1
