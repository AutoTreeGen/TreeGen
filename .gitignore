# =============================================================================
# AutoTreeGen / SmarTreeDNA — .gitignore
# =============================================================================

# ---- Секреты и окружение ----
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/
.secrets.baseline.local

# ---- Личные / чувствительные данные (НИКОГДА не коммитить) ----
# Личный GED-файл владельца
Ztree.ged
*Ztree*.ged
# Личные/приватные образцы для тестирования
packages/gedcom-parser/samples/personal/
# DNA-данные (special category по GDPR)
**/dna-data/
**/dna_kits/
*.dna.csv
*.dna.zip
*_dna_*.csv

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Python virtual envs
.venv/
venv/
ENV/
env/
.env-*/

# Python tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.hypothesis/
coverage.xml
*.cover
.cache

# uv
.uv/
uv.lock.local

# Jupyter
.ipynb_checkpoints/

# ---- Node / TypeScript ----
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/
.next/
.nuxt/
out/
build/
.turbo/
.vercel/
.cache/
*.tsbuildinfo
.swc/

# ---- IDE / редакторы ----
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini
.cursor/

# ---- Docker / dev ----
.docker/
docker-compose.override.yml
volumes/
data/

# ---- Логи и временные файлы ----
*.log
logs/
tmp/
temp/
.tmp/

# ---- Тестовые артефакты ----
test-results/
playwright-report/
playwright/.cache/

# ---- OS ----
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# ---- Terraform ----
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
crash.log
*.tfvars
!*.tfvars.example

# ---- Локальные файлы Claude ----
.claude/settings.local.json
.claude/cache/

# ---- pre-commit ----
.pre-commit-cache/
